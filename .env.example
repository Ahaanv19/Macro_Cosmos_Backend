# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# NEVER commit real secrets.

# --- Core security (REQUIRED in production) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=sess_python_flask
JWT_TOKEN_NAME=jwt_python_flask

# --- Admin / default users ---
ADMIN_USER=admin
ADMIN_UID=admin
ADMIN_PASSWORD=change-me-strong-password
DEFAULT_PASSWORD=change-me-strong-password
DEFAULT_USER=user
DEFAULT_UID=user
DEFAULT_USER_PASSWORD=change-me-strong-password

# --- Admin route hardening (optional) ---
# Comma-separated IPs / CIDR ranges allowed to hit admin routes. Empty = allow all.
ADMIN_IP_ALLOWLIST=
# Set to 1 only when running behind a trusted reverse proxy (e.g. nginx) so the
# real client IP is read from X-Forwarded-For for rate limiting / allowlisting.
TRUST_PROXY=
# Optional shared rate-limit store (e.g. redis://localhost:6379). Default in-memory.
RATELIMIT_STORAGE_URI=

# --- External API keys ---
GOOGLE_MAPS_API_KEY=your-google-maps-directions-key
TRIVIA_API_KEY=your-api-ninjas-key
GEMINI_API_KEY=your-gemini-key
GEMINI_SERVER=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent
GITHUB_TOKEN=your-github-token
GITHUB_TARGET_TYPE=user
GITHUB_TARGET_NAME=your-org-or-user

# --- Database (production MySQL; leave unset for local SQLite) ---
DB_ENDPOINT=
DB_USERNAME=
DB_PASSWORD=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Frontend URLs ---
FRONTEND_URL=https://your-user.github.io/SD_Auto_Frontend
FRONTEND_URL_LOCAL=http://127.0.0.1:4887
